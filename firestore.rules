rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'sndjy1986@gmail.com';
    }

    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Specific overrides for write access
    match /units/{unitId} { allow write: if isSignedIn(); }
    match /unitAssignments/{assignmentId} { allow write: if isSignedIn(); }
    match /shiftReports/{reportId} { allow write: if isSignedIn(); }
    match /reports/{reportId} { allow write: if isSignedIn(); }
    match /toneTests/{testId} { allow write: if isSignedIn(); }
    match /users/{userId} { allow write: if isSignedIn(); }
  }
}
